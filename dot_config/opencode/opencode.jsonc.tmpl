{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "default_agent": "dialogue",
  "lsp": {},
  "permission": {
    "bash": "allow"
  },
  // I use `mise exec --cd / -- ...` to launch MCP servers with the Node instance installed globally by Mise
  "mcp": {
    "fetch": {
      "type": "local",
      "command": ["mise", "exec", "--cd", "/", "--", "mcp-server-fetch"],
      "enabled": true,
      "environment": {
        "DEFAULT_LIMIT": "0"
      }
    },
    "context7": {
      "type": "local",
      "command": ["mise", "exec", "--cd", "/", "--", "context7-mcp", "--api-key", "{{ gopass "context7/apikey"}}"],
      "enabled": true,
    },
    "tavily": {
      "type": "local",
      "command": ["mise", "exec", "--cd", "/", "--", "tavily-mcp"],
      "environment": {
        "TAVILY_API_KEY": "{{ gopass "tavily/apikey" }}",
        "DEFAULT_PARAMETERS": "{\"include_images\": false, \"max_results\": 15, \"search_depth\": \"advanced\"}"
      },
      "enabled": true,
    },
    "exa": {
      "type": "local",
      "command": ["mise", "exec", "--cd", "/", "--", "exa-mcp-server"],
      "enabled": false,
      "environment": {
        "EXA_API_KEY": "{{ gopass "exa.ia/opencode-devbox/apikey" }}"
      }
    },
    "hindsight": {
      "enabled": true,
      "type": "remote",
      "url": "https://api.hindsight.sklein.internal/mcp/",
      "headers": {
        "Authorization": "Bearer {{ gopass "hindsight/mcp_token" }}"
      }
    },
    "playwright": {
      "type": "local",
      "command": ["mise", "exec", "--cd", "/", "--", "playwright-mcp", "--no-sandbox"],
      "enabled": false,
      "environment": {
        "PLAYWRIGHT_MCP_CDP_ENDPOINT": "http://127.0.0.1:9222"
      }
    },
    "browser-control": {
      "type": "local",
      "command": ["node", "{{ .chezmoi.homeDir }}/.local/share/browser-control-mcp/mcp-server/dist/server.js"],
      "enabled": false,
      "environment": {
        "EXTENSION_SECRET": "{{ gopass "browser-control-mcp/EXTENSION_SECRET" }}",
        "EXTENSION_PORT": "8090"
      }
    }
  },
  "plugin": [
    "@mohak34/opencode-notifier@0.2.8",
    "@slkiser/opencode-quota@3.10.1",
    "cc-safety-net@1.0.6",
    "opencode-vibeguard@0.1.0"
  ]
}
