# Source sklein-devbox environment variables (for SSH sessions)
if [ -f "${HOME}/.config/sklein-devbox/env" ]; then
    source "${HOME}/.config/sklein-devbox/env"
fi

export ZSH="$HOME/.oh-my-zsh"
export PATH="$HOME/.local/bin:$PATH"
ZSH_THEME=""
plugins=(git)
ZSH_COMPDUMP="${ZSH_CACHE_DIR:-$HOME/.cache/zsh}/.zcompdump"
source $ZSH/oh-my-zsh.sh

# History: 2 years limit (~730000 commands)
HISTSIZE=100000
SAVEHIST=730000
HISTFILE="$HOME/.zsh_history"

# Share history between all sessions
setopt SHARE_HISTORY
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_VERIFY
setopt APPEND_HISTORY
setopt HIST_EXPIRE_DUPS_FIRST

export GNUPGHOME="$HOME/.config/gnupg"
export PATH="$HOME/bin:$PATH"

if command -v starship &> /dev/null; then
    eval "$(starship init zsh)"
fi

if command -v gopass &> /dev/null; then
    source <(gopass completion zsh)
fi

# Refresh tmux status bar after each command
_tmux_refresh() {
    [[ -n "$TMUX" ]] && tmux refresh-client -S 2>/dev/null
}
precmd_functions+=( _tmux_refresh )

# Set tmux pane title to current directory
chpwd() {
  tmux select-pane -t "$TMUX_PANE" -T "$PWD" 2>/dev/null
}

# Set pane title on shell startup
if [[ -n "$TMUX_PANE" ]]; then
  tmux select-pane -t "$TMUX_PANE" -T "$PWD"
fi

eval "$(mise activate zsh 2>/dev/null)"

alias opencode="TMUX= command opencode"
export EDITOR=nvim
