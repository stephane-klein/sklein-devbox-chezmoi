export ZSH="$HOME/.oh-my-zsh"
export PATH="$HOME/.local/bin:$PATH"
ZSH_THEME=""
plugins=(git)
ZSH_COMPDUMP="${ZSH_CACHE_DIR:-$HOME/.cache/zsh}/.zcompdump"
source $ZSH/oh-my-zsh.sh

export GNUPGHOME="$HOME/.config/gnupg"
export PATH="$HOME/bin:$PATH"

if command -v starship &> /dev/null; then
    eval "$(starship init zsh)"
fi

if command -v gopass &> /dev/null; then
    source <(gopass completion zsh)
fi

# Set tmux window title to current directory
# Only updates if automatic-rename is on (preserves manual renames)
_tmux_window_title() {
    [[ -n "$TMUX" ]] || return
    local auto
    auto=$(tmux show-options -wqv automatic-rename 2>/dev/null)
    [[ "$auto" == "off" ]] || printf '\033k%s\033\\' "$PWD"
}
chpwd_functions+=( _tmux_window_title )
precmd_functions+=( _tmux_window_title )

# Refresh tmux status bar after each command
_tmux_refresh() {
    [[ -n "$TMUX" ]] && tmux refresh-client -S 2>/dev/null
}
precmd_functions+=( _tmux_refresh )

eval "$(mise activate zsh 2>/dev/null)"
